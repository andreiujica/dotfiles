# Use Catppuccin Mocha as the syntax highlighting theme. Consistent with the
# rest of the terminal colorscheme. Run `bat --list-themes` to see alternatives.
--theme="Catppuccin Mocha"

# Render italic text for tokens that support it (e.g. comments, keywords).
# Disable this if your terminal or multiplexer doesn't handle italic escape codes.
--italic-text=always
